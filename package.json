{
  "name": "wiiz",
  "version": "1.0.1",
  "description": "Repeatable repository onboarding from .wiiz/wizard.yaml.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js"
  ],
  "bin": {
    "wiiz": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "bun index.ts run",
    "cli": "bun index.ts",
    "validate": "bun index.ts validate",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^6.3.1",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
